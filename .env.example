# General Config
PROJECT_NAME="AI Radar"
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=ai_radar_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:<CHANGE_ME>@db:5432/ai_radar_db

# LLM Config (OpenAI compatible)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=90
LLM_CONNECT_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1
LLM_MAX_INPUT_CHARS=30000
LLM_MAX_OUTPUT_TOKENS=2500
LLM_ANALYSIS_ENABLED=false
LLM_STORE_RAW_RESPONSE=true

# Telegram Config
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_MODERATION_CHAT_ID=-1001234567890
TELEGRAM_CHANNEL_ID=-1009876543210
TELEGRAM_FEEDBACK_ENABLED=false
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_FEEDBACK_POLL_TIMEOUT_SECONDS=20
TELEGRAM_FEEDBACK_BATCH_LIMIT=100
TELEGRAM_FEEDBACK_CALLBACK_PREFIX=feedback

# Moderation Config
AUTO_APPROVAL_ENABLED=false
