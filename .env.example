# General Config
PROJECT_NAME="AI Radar"
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=ai_radar_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:<CHANGE_ME>@db:5432/ai_radar_db

# LLM Config (OpenAI compatible)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=90
LLM_CONNECT_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1
LLM_MAX_INPUT_CHARS=30000
LLM_MAX_OUTPUT_TOKENS=2500
LLM_ANALYSIS_ENABLED=false
LLM_STORE_RAW_RESPONSE=true
LLM_PROMPT_VERSION=phase5-v1
LLM_ANALYSIS_VERSION=1.0
LLM_SCORE_VERSION=1.0
LLM_ANALYSIS_MAX_ATTEMPTS=3

# Telegram Config
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_MODERATION_CHAT_ID=-1001234567890
TELEGRAM_CHANNEL_ID=-1009876543210
TELEGRAM_FEEDBACK_ENABLED=false
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_FEEDBACK_POLL_TIMEOUT_SECONDS=20
TELEGRAM_FEEDBACK_BATCH_LIMIT=100
TELEGRAM_FEEDBACK_CALLBACK_PREFIX=feedback

# Moderation Config
MODERATION_ENABLED=true
MODERATION_RULES_VERSION=1.0
MODERATION_MAX_AGE_DAYS=30
MODERATION_DIGEST_MIN_SCORE=5.0
MODERATION_REVIEW_MIN_SCORE=7.0
MODERATION_PRIORITY_MIN_SCORE=8.5
MODERATION_MIN_CONFIDENCE=0.60
MODERATION_PRIORITY_MIN_CONFIDENCE=0.75
MODERATION_BATCH_LIMIT=50
# Auto-approve/reject queue items by rule outcome, without human review. Off by default (opt-in).
MODERATION_AUTO_DECISION_ENABLED=false
MODERATION_ALLOW_LEGACY_ANALYSIS=false

# Scheduler Config
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_MAX_PARALLEL_RUNS=1
SCHEDULER_LOCK_TIMEOUT=1800
SCHEDULER_DEFAULT_LIMIT=10
# Automatically publish approved items after each scheduler pipeline run. Off by default (opt-in).
SCHEDULER_AUTO_PUBLISH_ENABLED=false
SCHEDULER_PUBLISH_LIMIT=10
# Automatically retry failed Telegram publications after each scheduler tick. Off by default (opt-in).
SCHEDULER_PUBLISH_RETRY_ENABLED=false
SCHEDULER_PUBLISH_MAX_RETRIES=3
SCHEDULER_PUBLISH_RETRY_BACKOFF_MINUTES=15
